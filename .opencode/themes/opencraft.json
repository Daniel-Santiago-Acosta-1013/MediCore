    "syntaxVariable": { "dark": "snow", "light": "ink" },
    "syntaxString": { "dark": "grassBright", "light": "leaf" },
    "syntaxNumber": { "dark": "gold", "light": "goldDeep" },
    "syntaxType": { "dark": "lapis", "light": "lapisDeep" },
    "syntaxOperator": { "dark": "dirtBright", "light": "dirt" },
