    "diffContextBg": { "dark": "cave1", "light": "parchmentPanel" },
    "diffLineNumber": { "dark": "stoneDim", "light": "inkMuted" },
    "diffAddedLineNumberBg": { "dark": "#182516", "light": "#cfdcbf" },
    "diffRemovedLineNumberBg": { "dark": "#281310", "light": "#e5c2b7" },
